---

---

<section id="contact" class="section-padding max-w-6xl mx-auto">
  <div class="text-center mb-12" data-reveal>
    <p class="text-sm font-mono mb-2" style="color: var(--color-accent);">
      // contacto
    </p>
    <h2 class="section-title">Hablemos</h2>
    <p
      class="text-base mt-2 max-w-lg mx-auto"
      style="color: var(--color-text-muted);"
    >
      ¿Tienes un proyecto o posición que encaje? Estoy disponible para nuevas
      oportunidades.
    </p>
  </div>

  <div id="contact-card" class="max-w-2xl mx-auto">
    <div class="glass rounded-2xl p-8 space-y-6">
      <!-- Direct contact -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="mailto:juliangarcia940@gmail.com"
          class="flex-1 flex items-center gap-3 p-4 rounded-xl transition-all duration-200 hover:scale-[1.02]"
          style="background: rgba(34,211,238,0.06); border: 1px solid rgba(34,211,238,0.15); color: var(--color-primary);"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
            ></path><polyline points="22,6 12,13 2,6"></polyline>
          </svg>
          <div>
            <p class="text-xs" style="color: var(--color-text-muted);">Email</p>
            <p class="text-sm font-medium">juliangarcia940@gmail.com</p>
          </div>
        </a>
        <a
          href="https://linkedin.com/in/juliangarciapallas"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 flex items-center gap-3 p-4 rounded-xl transition-all duration-200 hover:scale-[1.02]"
          style="background: rgba(168,85,247,0.06); border: 1px solid rgba(168,85,247,0.15); color: var(--color-secondary);"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
          <div>
            <p class="text-xs" style="color: var(--color-text-muted);">
              LinkedIn
            </p>
            <p class="text-sm font-medium">juliangarciapallas</p>
          </div>
        </a>
      </div>

      <!-- Contact form -->
      <form id="contact-form" class="space-y-4" novalidate>
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label
              for="contact-name"
              class="text-xs font-medium"
              style="color: var(--color-text-muted);">Nombre</label
            >
            <input
              id="contact-name"
              name="name"
              type="text"
              required
              placeholder="Tu nombre"
              class="w-full px-4 py-2.5 rounded-xl text-sm outline-none transition-all duration-200"
              style="background: rgba(255,255,255,0.04); border: 1px solid var(--color-border); color: var(--color-text-base);"
            />
          </div>
          <div class="space-y-1.5">
            <label
              for="contact-email"
              class="text-xs font-medium"
              style="color: var(--color-text-muted);">Email</label
            >
            <input
              id="contact-email"
              name="email"
              type="email"
              required
              placeholder="tu@email.com"
              class="w-full px-4 py-2.5 rounded-xl text-sm outline-none transition-all duration-200"
              style="background: rgba(255,255,255,0.04); border: 1px solid var(--color-border); color: var(--color-text-base);"
            />
          </div>
        </div>
        <div class="space-y-1.5">
          <label
            for="contact-message"
            class="text-xs font-medium"
            style="color: var(--color-text-muted);">Mensaje</label
          >
          <textarea
            id="contact-message"
            name="message"
            required
            rows="4"
            placeholder="Cuéntame sobre tu proyecto o posición..."
            class="w-full px-4 py-2.5 rounded-xl text-sm outline-none resize-none transition-all duration-200"
            style="background: rgba(255,255,255,0.04); border: 1px solid var(--color-border); color: var(--color-text-base);"
          ></textarea>
        </div>
        <button
          id="contact-submit"
          type="submit"
          class="w-full py-3 rounded-xl text-sm font-medium transition-all duration-200 hover:scale-[1.02] hover:opacity-90"
          style="background: linear-gradient(135deg, var(--color-primary), var(--color-secondary)); color: #050508;"
        >
          Enviar mensaje
        </button>
        <div
          id="contact-feedback"
          class="hidden text-center text-sm py-2 rounded-xl"
        >
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById(
    "contact-form",
  ) as HTMLFormElement | null;
  const submitBtn = document.getElementById(
    "contact-submit",
  ) as HTMLButtonElement | null;
  const feedback = document.getElementById(
    "contact-feedback",
  ) as HTMLElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    if (submitBtn) {
      submitBtn.textContent = "Enviando...";
      submitBtn.disabled = true;
    }

    // FormSubmit.co — replace with your email or use EmailJS / Netlify Forms
    const data = new FormData(form);
    try {
      const res = await fetch(
        `https://formsubmit.co/ajax/juliangarcia940@gmail.com`,
        {
          method: "POST",
          headers: { Accept: "application/json" },
          body: data,
        },
      );

      if (res.ok) {
        form.reset();
        if (feedback) {
          feedback.textContent = "✓ Mensaje enviado. Te respondo en breve.";
          feedback.style.background = "rgba(34,211,238,0.1)";
          feedback.style.color = "var(--color-primary)";
          feedback.classList.remove("hidden");
        }
      } else {
        throw new Error("Error al enviar");
      }
    } catch {
      if (feedback) {
        feedback.textContent =
          "✗ Error al enviar. Escríbeme directamente a juliangarcia940@gmail.com";
        feedback.style.background = "rgba(236,72,153,0.1)";
        feedback.style.color = "var(--color-accent)";
        feedback.classList.remove("hidden");
      }
    } finally {
      if (submitBtn) {
        submitBtn.textContent = "Enviar mensaje";
        submitBtn.disabled = false;
      }
    }
  });
</script>
