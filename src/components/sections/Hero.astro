---
import HeroCanvas from '../canvas/HeroCanvas.astro';

// Split name into individual character spans for GSAP animation
const name = 'Julián García Pallas';
const tagline = 'Backend Architect · Fullstack Engineer';
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Canvas background -->
  <HeroCanvas />

  <!-- Radial gradient overlay to focus text -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(34,211,238,0.04) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <!-- Status badge -->
    <div
      id="hero-badge"
      class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium mb-8"
      style="background: rgba(34,211,238,0.08); border: 1px solid rgba(34,211,238,0.2); color: var(--color-primary);"
    >
      <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background: var(--color-primary);"></span>
      Disponible para nuevas oportunidades
    </div>

    <!-- Name with character split -->
    <h1
      id="hero-name"
      class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-4 leading-tight"
      style="perspective: 400px;"
    >
      {name.split('').map((char) => (
        <span
          class="char inline-block"
          style={char === ' ' ? 'width: 0.3em;' : ''}
        >{char === ' ' ? '\u00A0' : char}</span>
      ))}
    </h1>

    <!-- Tagline with word split -->
    <p
      id="hero-tagline"
      class="text-xl sm:text-2xl md:text-3xl font-light mb-3 gradient-text"
    >
      {tagline.split(' ').map((word) => (
        <span class="word inline-block mr-2">{word}</span>
      ))}
    </p>

    <!-- Sub tagline -->
    <p
      id="hero-sub"
      class="text-base sm:text-lg max-w-xl mx-auto mb-10"
      style="color: var(--color-text-muted);"
    >
      Java · TypeScript · Node.js · React · Python · AI
    </p>

    <!-- CTAs -->
    <div id="hero-cta" class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#projects"
        class="px-6 py-3 rounded-full font-medium text-sm transition-all duration-200 hover:scale-105 hover:shadow-lg"
        style="background: var(--color-primary); color: #050508;"
      >
        Ver proyectos
      </a>
      <a
        href="#contact"
        class="px-6 py-3 rounded-full font-medium text-sm transition-all duration-200 hover:scale-105 glass"
        style="color: var(--color-text-base);"
      >
        Contactar
      </a>
    </div>

    <!-- Scroll hint -->
    <div id="hero-scroll" class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
      <span class="text-xs" style="color: var(--color-text-faint);">scroll</span>
      <div class="w-px h-8 animate-bounce" style="background: linear-gradient(to bottom, var(--color-text-faint), transparent);"></div>
    </div>
  </div>
</section>

<script>
  import { initHeroAnimations } from '../../scripts/gsap/hero';
  initHeroAnimations();
</script>
