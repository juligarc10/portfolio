---
const skillGroups = [
  {
    category: 'Backend',
    emoji: '⚙️',
    skills: [
      { name: 'Java 17 / Spring Boot', level: 90 },
      { name: 'TypeScript / Node.js', level: 85 },
      { name: 'Clean Architecture / Hexagonal', level: 88 },
      { name: 'REST · GraphQL · WebSocket', level: 85 },
      { name: 'DDD · CQRS · Event Sourcing', level: 76 },
      { name: 'PostgreSQL · MongoDB', level: 80 },
    ],
  },
  {
    category: 'Frontend',
    emoji: '🎨',
    skills: [
      { name: 'React · Next.js 15', level: 82 },
      { name: 'Astro', level: 83 },
      { name: 'React Native · Expo', level: 78 },
      { name: 'Tailwind CSS', level: 88 },
      { name: 'GSAP · Canvas API', level: 75 },
    ],
  },
  {
    category: 'DevOps & Seguridad',
    emoji: '🚀',
    skills: [
      { name: 'Docker · Docker Compose', level: 83 },
      { name: 'Keycloak · OAuth2 · OIDC', level: 87 },
      { name: 'SCIM 2.0', level: 82 },
      { name: 'Bitbucket Pipelines · CI/CD', level: 76 },
      { name: 'SonarQube · Gradle', level: 73 },
    ],
  },
  {
    category: 'AI / ML',
    emoji: '🤖',
    skills: [
      { name: 'RAG · ChromaDB · Embeddings', level: 73 },
      { name: 'LangChain · Agents', level: 70 },
      { name: 'Python · FastAPI', level: 76 },
      { name: 'Prompt Engineering', level: 79 },
    ],
  },
] as const;
---

<section id="skills" class="section-padding max-w-6xl mx-auto">
  <div class="text-center mb-14" id="skills-title" data-reveal>
    <p class="text-sm font-mono mb-2" style="color: var(--color-secondary);">// tecnologías</p>
    <h2 class="section-title">Stack técnico</h2>
    <p class="text-base mt-2 max-w-lg mx-auto" style="color: var(--color-text-muted);">
      Polyglot por elección, arquitecto por vocación.
    </p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {skillGroups.map((group) => (
      <div class="skill-group glass rounded-2xl p-6 space-y-4">
        <div class="flex items-center gap-2 mb-5">
          <span class="text-xl">{group.emoji}</span>
          <h3 class="font-semibold text-sm" style="color: var(--color-text-base);">{group.category}</h3>
        </div>
        <div class="space-y-4">
          {group.skills.map((skill) => (
            <div>
              <div class="flex justify-between items-center mb-1.5">
                <span class="text-xs" style="color: var(--color-text-muted);">{skill.name}</span>
              </div>
              <div class="h-1 rounded-full overflow-hidden" style="background: rgba(255,255,255,0.06);">
                <div
                  class="skill-bar-fill h-full rounded-full"
                  data-level={skill.level}
                  style={`width: 0%; background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));`}
                ></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  import { initSkillsAnimation } from '../../scripts/gsap/skills';
  initSkillsAnimation();
</script>
