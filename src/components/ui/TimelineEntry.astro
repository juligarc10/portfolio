---
import TechTag from './TechTag.astro';

interface Props {
  company: string;
  role: string;
  period: string;
  location: string;
  techs: readonly string[];
  highlights: readonly string[];
  index: number;
}
const { company, role, period, location, techs, highlights, index } = Astro.props;
const isLeft = index % 2 === 0;
---

<div class={`timeline-entry relative ${isLeft ? 'md:pr-1/2 md:text-right' : 'md:pl-1/2 md:ml-0'} pb-12`}>
  <!-- Connector dot -->
  <div
    class="absolute top-2 hidden md:block w-3 h-3 rounded-full"
    style={`background: var(--color-primary); border: 2px solid var(--color-bg-base); box-shadow: 0 0 0 4px rgba(34,211,238,0.15); ${isLeft ? 'right: -6px; transform: translateX(50%);' : 'left: -6px; transform: translateX(-50%);'}`}
    aria-hidden="true"
  ></div>

  <!-- Card -->
  <div
    class={`glass rounded-2xl p-5 ${isLeft ? 'md:mr-8' : 'md:ml-8'}`}
    style="border-color: rgba(34,211,238,0.1);"
  >
    <div class={`flex flex-wrap items-start gap-2 justify-between mb-3 ${isLeft ? 'md:flex-row-reverse' : ''}`}>
      <div>
        <h3 class="font-semibold text-base" style="color: var(--color-text-base);">{role}</h3>
        <p class="text-sm font-medium" style="color: var(--color-primary);">{company}</p>
      </div>
      <div class={`text-right ${isLeft ? 'md:text-left' : ''}`}>
        <p class="text-xs font-mono" style="color: var(--color-text-muted);">{period}</p>
        <p class="text-xs" style="color: var(--color-text-faint);">{location}</p>
      </div>
    </div>

    <ul class="space-y-1.5 mb-3">
      {highlights.map((h) => (
        <li class="text-xs flex gap-2" style="color: var(--color-text-muted);">
          <span style="color: var(--color-primary); flex-shrink: 0;">▸</span>
          {h}
        </li>
      ))}
    </ul>

    <div class={`flex flex-wrap gap-1.5 ${isLeft ? 'md:justify-end' : ''}`}>
      {techs.slice(0, 6).map((tech) => <TechTag tech={tech} />)}
    </div>
  </div>
</div>
