---
import TechTag from './TechTag.astro';

interface Props {
  title: string;
  tagline: string;
  period: string;
  techs: readonly string[];
  categories: readonly string[];
  links: { github?: string; live?: string };
  highlights: readonly string[];
  featured?: boolean;
}

const { title, tagline, period, techs, categories, links, highlights, featured } = Astro.props;
---

<article
  class="project-card glass rounded-2xl overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.02] hover:border-opacity-50"
  style={featured ? 'border-color: rgba(34,211,238,0.2);' : ''}
  data-categories={categories.join(',')}
>
  <!-- Image placeholder -->
  <div
    class="h-40 w-full flex items-center justify-center relative overflow-hidden"
    style="background: linear-gradient(135deg, rgba(34,211,238,0.06), rgba(168,85,247,0.06));"
  >
    {featured && (
      <span
        class="absolute top-3 left-3 text-xs px-2 py-0.5 rounded-full font-medium"
        style="background: rgba(34,211,238,0.15); color: var(--color-primary); border: 1px solid rgba(34,211,238,0.25);"
      >
        Featured
      </span>
    )}
    <span class="text-4xl opacity-30">⬡</span>
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col gap-3 flex-1">
    <div>
      <div class="flex items-start justify-between gap-2 mb-1">
        <h3 class="font-semibold text-base" style="color: var(--color-text-base);">{title}</h3>
        <span class="text-xs shrink-0 mt-0.5" style="color: var(--color-text-faint);">{period}</span>
      </div>
      <p class="text-sm" style="color: var(--color-text-muted);">{tagline}</p>
    </div>

    <!-- Techs -->
    <div class="flex flex-wrap gap-1.5">
      {techs.slice(0, 5).map((tech) => <TechTag tech={tech} />)}
      {techs.length > 5 && (
        <span class="text-xs" style="color: var(--color-text-faint);">+{techs.length - 5}</span>
      )}
    </div>

    <!-- Highlights (collapsible) -->
    {highlights.length > 0 && (
      <details class="group mt-1">
        <summary
          class="text-xs cursor-pointer select-none transition-colors duration-200 hover:opacity-100 list-none flex items-center gap-1"
          style="color: var(--color-text-faint);"
        >
          <svg class="w-3 h-3 transition-transform group-open:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 18l6-6-6-6"/>
          </svg>
          Ver highlights
        </summary>
        <ul class="mt-2 space-y-1.5 pl-2">
          {highlights.map((h) => (
            <li class="text-xs flex gap-2" style="color: var(--color-text-muted);">
              <span style="color: var(--color-primary); flex-shrink: 0;">▸</span>
              {h}
            </li>
          ))}
        </ul>
      </details>
    )}

    <!-- Footer links -->
    <div class="flex items-center gap-3 mt-auto pt-2">
      {links.github && (
        <a
          href={links.github}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-xs transition-colors duration-200 hover:opacity-100"
          style="color: var(--color-text-muted);"
          aria-label={`Ver código de ${title} en GitHub`}
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          Código
        </a>
      )}
      {links.live && (
        <a
          href={links.live}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-xs transition-colors duration-200 hover:opacity-100"
          style="color: var(--color-primary);"
          aria-label={`Ver demo de ${title}`}
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
          </svg>
          Demo
        </a>
      )}
    </div>
  </div>
</article>
