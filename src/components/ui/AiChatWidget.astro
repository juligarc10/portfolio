---
const RAG_URL = 'https://frontend.jgp-server.com/';

const sampleQuestions = [
  '¿Qué stack técnico domina?',
  '¿Cuál es su experiencia con Keycloak?',
  '¿Ha trabajado con arquitectura hexagonal?',
];
---

<!-- Floating AI chat widget -->
<div id="ai-widget" class="ai-widget" aria-label="Asistente IA">
  <!-- Tooltip card (shown on hover) -->
  <div id="ai-tooltip" class="ai-tooltip" role="tooltip">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs font-mono" style="color: var(--color-primary);">// asistente IA</span>
    </div>
    <p class="text-xs mb-3" style="color: var(--color-text-muted); line-height: 1.6;">
      Tengo un sistema RAG con información sobre mí. Puedes preguntarle cualquier cosa.
    </p>
    <ul class="space-y-1.5 mb-4">
      {sampleQuestions.map((q) => (
        <li>
          <a
            href={RAG_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-xs transition-colors duration-150 hover:opacity-100 group"
            style="color: var(--color-text-faint);"
          >
            <span style="color: var(--color-primary); flex-shrink: 0;" class="group-hover:translate-x-0.5 transition-transform">›</span>
            {q}
          </a>
        </li>
      ))}
    </ul>
    <a
      href={RAG_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-center gap-2 w-full py-2 rounded-lg text-xs font-medium transition-all duration-200 hover:opacity-90"
      style="background: linear-gradient(135deg, var(--color-primary), var(--color-secondary)); color: #050508;"
    >
      Abrir asistente
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
      </svg>
    </a>
    <!-- Arrow pointing down-right to the button -->
    <div class="ai-tooltip-arrow" aria-hidden="true"></div>
  </div>

  <!-- Trigger button -->
  <a
    href={RAG_URL}
    target="_blank"
    rel="noopener noreferrer"
    id="ai-btn"
    class="ai-btn"
    aria-label="Abrir asistente IA"
  >
    <!-- Pulse ring -->
    <span class="ai-pulse" aria-hidden="true"></span>
    <!-- Icon: AI / chat sparkle -->
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
      <path d="M9 10h.01M12 10h.01M15 10h.01" stroke-width="2.5"/>
    </svg>
  </a>
</div>

<style>
  .ai-widget {
    position: fixed;
    bottom: 1.75rem;
    right: 1.75rem;
    z-index: 40;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .ai-tooltip {
    width: 220px;
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(10, 10, 18, 0.95);
    border: 1px solid rgba(34, 211, 238, 0.2);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(34, 211, 238, 0.05);
    opacity: 0;
    transform: translateY(8px) scale(0.96);
    transform-origin: bottom right;
    pointer-events: none;
    transition: opacity 200ms ease, transform 200ms ease;
  }

  .ai-widget:hover .ai-tooltip,
  .ai-widget:focus-within .ai-tooltip {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .ai-tooltip-arrow {
    position: absolute;
    bottom: -6px;
    right: 20px;
    width: 12px;
    height: 12px;
    background: rgba(10, 10, 18, 0.95);
    border-right: 1px solid rgba(34, 211, 238, 0.2);
    border-bottom: 1px solid rgba(34, 211, 238, 0.2);
    transform: rotate(45deg);
  }

  .ai-btn {
    position: relative;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(34,211,238,0.15), rgba(168,85,247,0.15));
    border: 1px solid rgba(34, 211, 238, 0.35);
    color: var(--color-primary);
    transition: transform 200ms ease, box-shadow 200ms ease, background 200ms ease;
    box-shadow: 0 0 20px rgba(34, 211, 238, 0.15);
    text-decoration: none;
  }

  .ai-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 0 32px rgba(34, 211, 238, 0.3);
    background: linear-gradient(135deg, rgba(34,211,238,0.25), rgba(168,85,247,0.25));
  }

  .ai-pulse {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1.5px solid rgba(34, 211, 238, 0.4);
    animation: ai-pulse 2.5s ease-out infinite;
  }

  @keyframes ai-pulse {
    0%   { transform: scale(1); opacity: 0.6; }
    70%  { transform: scale(1.4); opacity: 0; }
    100% { transform: scale(1.4); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-pulse { animation: none; }
    .ai-tooltip { transition: none; }
  }
</style>

<script>
  import { gsap } from '../../scripts/gsap/deps';

  // Entrance animation: slide up from bottom after hero finishes
  gsap.from('#ai-widget', {
    y: 60,
    opacity: 0,
    duration: 0.6,
    ease: 'back.out(1.4)',
    delay: 3.2,
  });
</script>
